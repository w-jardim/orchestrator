# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-secret-min-32-chars-change-in-prod
JWT_ACCESS_EXPIRES=15m

# ─── MYSQL ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=orchestrator
DB_PASS=orchestrator_pass
DB_NAME=plagard_orchestrator

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# ─── CORS & SECURITY ────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# ─── TENANT DEFAULTS ────────────────────────────────────────────────────────
DEFAULT_TENANT_NAME=Default Tenant
DEFAULT_TENANT_SLUG=default
DEFAULT_TENANT_PLAN=FREE

# ─── DOCKER OPERATIONS ─────────────────────────────────────────────────────
DOCKER_TIMEOUT_MS=5000
DOCKER_BUILD_TIMEOUT_MS=120000
DOCKER_RUN_TIMEOUT_MS=30000
DOCKER_RETRY_COUNT=2
DOCKER_RETRY_DELAY_MS=1000
DOCKER_ALLOWED_CONTAINERS=all
DOCKER_ALLOWED_IMAGES=all

# ─── RATE LIMITING ─────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
DOCKER_RATE_LIMIT_WINDOW_MS=60000
DOCKER_RATE_LIMIT_MAX=50

# ─── DEPLOYMENT CONFIG ────────────────────────────────────────────────────
DEPLOY_FAILED_RETENTION_HOURS=168
DEPLOY_MAX_ENV_VARS=50

# ─── WORKER / BACKGROUND JOBS ─────────────────────────────────────────────
WORKER_HEARTBEAT_KEY=worker:heartbeat
WORKER_HEARTBEAT_TTL_MS=30000
