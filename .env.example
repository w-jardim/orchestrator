# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m

# ─── MYSQL ───────────────────────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_USER=orchestrator
DB_PASS=orchestrator_pass
DB_NAME=plagard_orchestrator

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASS=

# ─── RATE LIMIT ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
